# Local dev env vars (copy values from Vercel Project Settings → Environment Variables)
#
# For Neon/Vercel Postgres, set DATABASE_URL to the pooled URL.
# Set DIRECT_URL to the unpooled URL (used for migrations).
DATABASE_URL=
DIRECT_URL=

# Auth.js / NextAuth
# Note: code references NEXTAUTH_URL (preferred) and falls back to VERCEL_URL.
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=

# Resend (magic link email)
RESEND_API_KEY=
EMAIL_FROM=

# Cron auth (protects /api/cron/scheduled-jobs)
CRON_SECRET=

# KPI Google Sheet sync sources
LG_L10_KPI_SPREADSHEET_ID=
LG_L10_KPI_SHEET_NAME=
LG_TIMEKEEPER_KPI_SPREADSHEET_ID=
LG_TIMEKEEPER_KPI_SHEET_NAME=
