generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  STAFF
  ADMIN
  CRM_AGENT_PH
  CRM_AGENT_US
}

enum MatterStatus {
  DRAFT
  INTAKE_IN_PROGRESS
  READY_TO_GENERATE
  GENERATED
}

enum DocumentType {
  ADVANCE_MEDICAL_DIRECTIVE
  // Future
  JOINT_TRUST_PORTFOLIO
}

enum ContactState {
  VA
  DC
  MD
  OTHER
  UNKNOWN
}

enum CrmTaskType {
  PRE_SHOW
  POST_SHOW
  RESCUE_CLICK
  INBOUND_REPLY
  REFERRAL_OOJ
}

enum CrmPriority {
  HOT
  WARM
  COLD
}

enum CrmOwnerTeam {
  PH
  US
}

enum CrmTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum CrmDisposition {
  SCHEDULED_DISCOVERY
  INTERESTED_FOLLOW_UP
  NOT_INTERESTED
  NO_ANSWER_RETRY
  LEFT_VOICEMAIL
  WRONG_NUMBER
  DISQUALIFIED_JURISDICTION
  REFERRED_TO_OVERTURE
  BOOKING_LINK_SENT
}

enum CrmProvider {
  RINGCENTRAL
}

enum CrmMessageDirection {
  INBOUND
  OUTBOUND
}

enum CrmMessageStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  RECEIVED
}

enum CrmVerificationPurpose {
  REGISTRATION
  WATCH_ROOM
}

enum CrmAppointmentStatus {
  SCHEDULED
  SHOWED
  NO_SHOW
  CANCELED
  RESCHEDULED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  role          UserRole  @default(STAFF)

  accounts      Account[]
  sessions      Session[]

  matters       Matter[]  @relation("MattersCreatedBy")

  ringCentralConnection RingCentralConnection?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model RingCentralConnection {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  rcUserId     String?
  rcExtensionId String?

  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Matter {
  id          String       @id @default(cuid())
  status      MatterStatus @default(DRAFT)

  // v0: keep it simple; later we can normalize people/roles.
  displayName String

  createdById String
  createdBy   User         @relation("MattersCreatedBy", fields: [createdById], references: [id])

  intake      IntakeResponse?
  documents   GeneratedDocument[]
  pipelineLinks MatterPipeline[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model IntakeResponse {
  id        String   @id @default(cuid())
  matterId  String   @unique
  matter    Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)

  // v0: JSON blob; evolve to structured columns as forms stabilize.
  data      Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GeneratedDocument {
  id        String       @id @default(cuid())
  matterId  String
  matter    Matter       @relation(fields: [matterId], references: [id], onDelete: Cascade)

  type      DocumentType

  // For MVP we can store generated content as a Blob later; for now store metadata.
  fileName  String?
  fileUrl   String?

  createdAt DateTime     @default(now())

  @@index([matterId])
}

model CrmContact {
  id        String       @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phoneE164 String       @unique
  state     ContactState @default(UNKNOWN)

  phoneVerifiedAt DateTime?

  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  registrations CrmRegistration[]
  tasks         CrmTask[]
  threads       CrmMessageThread[]
  verifications CrmVerification[] @relation("CrmContactVerifications")

  prequalSubmissions CrmPrequalSubmission[]
  pipelineRecords    CrmLeadPipeline[]
}

model CrmCampaign {
  id        String @id @default(cuid())
  slug      String @unique
  name      String

  // Config defaults (MVP)
  defaultSenderName String @default("Noah")
  bookingUrl        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  showings       CrmShowing[]
  registrations  CrmRegistration[]
  tasks          CrmTask[]

  prequalSubmissions CrmPrequalSubmission[]
  pipelineRecords    CrmLeadPipeline[]
  dailySpends        CrmDailySpend[]
}

model CrmShowing {
  id         String      @id @default(cuid())
  campaignId String
  campaign   CrmCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  startsAt   DateTime
  endsAt     DateTime

  createdAt  DateTime @default(now())

  registrations CrmRegistration[]
  tasks         CrmTask[]

  @@index([campaignId])
  @@index([startsAt])
}

model CrmRegistration {
  id        String @id @default(cuid())

  contactId String
  contact   CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  campaignId String
  campaign   CrmCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  showingId String
  showing   CrmShowing @relation(fields: [showingId], references: [id], onDelete: Cascade)

  status    String @default("REGISTERED") // TODO enum later when we wire attendance
  watchToken String? @unique

  phoneVerifiedAt DateTime?

  createdAt DateTime @default(now())

  verifications CrmVerification[] @relation("CrmRegistrationVerifications")

  prequalSubmissions CrmPrequalSubmission[] @relation("CrmRegistrationPrequal")

  @@index([campaignId])
  @@index([showingId])
  @@index([contactId])
}

model CrmVerification {
  id        String @id @default(cuid())
  purpose   CrmVerificationPurpose

  contactId String
  contact   CrmContact @relation("CrmContactVerifications", fields: [contactId], references: [id], onDelete: Cascade)

  registrationId String?
  registration   CrmRegistration? @relation("CrmRegistrationVerifications", fields: [registrationId], references: [id], onDelete: Cascade)

  codeHash  String
  expiresAt DateTime
  attempts  Int @default(0)

  sentAt    DateTime @default(now())
  verifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
  @@index([registrationId])
  @@index([purpose, expiresAt])
}

model CrmPrequalSubmission {
  id        String @id @default(cuid())

  contactId String
  contact   CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  campaignId String
  campaign   CrmCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  registrationId String?
  registration   CrmRegistration? @relation("CrmRegistrationPrequal", fields: [registrationId], references: [id], onDelete: SetNull)

  source    String @default("internal") // typeform|internal
  qualified Boolean @default(false)

  // Denormalized key answers for reporting
  estatePlanningStage String?
  primaryConcern      String?
  docsInPlace         String[]
  estateWorthBand     String?
  investReady         Boolean?
  readyToStart        String?
  additionalNotes     String?

  answers   Json

  createdAt DateTime @default(now())

  @@index([campaignId, createdAt])
  @@index([contactId, createdAt])
}

model CrmLeadPipeline {
  id         String @id @default(cuid())

  contactId  String
  contact    CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  campaignId String
  campaign   CrmCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  dateAdded  DateTime @default(now())
  additionalNotes String?

  intakeCallAttempted Boolean @default(false)
  intakeCallAttemptedAt DateTime?

  appt1Scheduled Boolean @default(false)
  appt1At        DateTime?
  appt1Status    CrmAppointmentStatus?

  leadQualityScore Int?

  appt2Scheduled Boolean @default(false)
  appt2At        DateTime?
  appt2Status    CrmAppointmentStatus?

  // Closing metrics (manual for now)
  closed          Boolean @default(false)
  cashCollectedCents Int @default(0)
  revenueCents       Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contactId, campaignId])
  @@index([campaignId, dateAdded])
}

model CrmDailySpend {
  id        String @id @default(cuid())

  campaignId String
  campaign   CrmCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // Store at midnight ET as a DateTime for now (we'll enforce in UI).
  day       DateTime
  amountCents Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, day])
  @@index([campaignId, day])
}

// --- Matter pipelines (Kanban) ---

model MatterPipeline {
  id         String @id @default(cuid())

  matterId   String
  matter     Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  stageId    String
  stage      PipelineStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  // ordering within a stage column (optional; used later)
  sortKey    Int @default(0)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([matterId, pipelineId])
  @@index([pipelineId, stageId])
  @@index([matterId])
}

model Pipeline {
  id          String @id @default(cuid())
  name        String
  description String?
  sortOrder   Int @default(0)

  stages      PipelineStage[]
  matterLinks MatterPipeline[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PipelineStage {
  id         String @id @default(cuid())
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  name       String
  colorHex   String? // optional UI color
  sortOrder  Int @default(0)

  matters    MatterPipeline[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pipelineId, sortOrder])
}

model CrmTask {
  id         String @id @default(cuid())
  contactId  String
  contact    CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  campaignId String
  campaign   CrmCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  showingId  String?
  showing    CrmShowing? @relation(fields: [showingId], references: [id], onDelete: SetNull)

  type       CrmTaskType
  priority   CrmPriority
  ownerTeam  CrmOwnerTeam
  status     CrmTaskStatus @default(OPEN)

  dueAt      DateTime
  lastTouchAt DateTime?

  disposition CrmDisposition?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, dueAt])
  @@index([campaignId])
  @@index([contactId])
}

model CrmMessageThread {
  id        String @id @default(cuid())

  contactId String
  contact   CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  provider  CrmProvider
  providerConversationId String?

  lastMessageAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  CrmMessage[]

  @@index([contactId])
}

model CrmMessage {
  id        String @id @default(cuid())

  threadId  String
  thread    CrmMessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  direction CrmMessageDirection
  fromNumberE164 String
  toNumberE164   String
  body      String

  providerMessageId String? @unique
  status    CrmMessageStatus

  sentAt    DateTime?
  receivedAt DateTime?

  createdAt DateTime @default(now())

  @@index([threadId, createdAt])
}
