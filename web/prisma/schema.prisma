generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  STAFF
  ADMIN
  CRM_AGENT_PH
  CRM_AGENT_US
}

enum MatterStatus {
  DRAFT
  INTAKE_IN_PROGRESS
  READY_TO_GENERATE
  GENERATED
}

enum DocumentType {
  ADVANCE_MEDICAL_DIRECTIVE
  // Future
  JOINT_TRUST_PORTFOLIO
}

enum DocumentTemplateKind {
  REPRESENTATION_AGREEMENT
  HR_DOCUMENT
  CONSENT
  AUTHORIZATION
  ACKNOWLEDGEMENT
}

enum SigningProvider {
  DOCUMENSO
}

enum SigningPacketStatus {
  DRAFT
  SENT
  COMPLETED
  REJECTED
  ERROR
}

enum ContactState {
  VA
  DC
  MD
  OTHER
  UNKNOWN
}

enum ContactCategory {
  CLIENT
  VENDOR
  REFERRER
  PROFESSIONAL_ADVISOR
  GENERAL
}

enum ContactProfessionalType {
  FINANCIAL_ADVISOR
  CPA
  INSURANCE
  BANKER
  REALTOR
  CARE_MANAGER
  ATTORNEY
  OTHER
}

enum ReferralSourceStatus {
  PROSPECT
  ACTIVE
  INACTIVE
}

enum CrmTaskType {
  PRE_SHOW
  POST_SHOW
  RESCUE_CLICK
  INBOUND_REPLY
  REFERRAL_OOJ
}

enum CrmPriority {
  HOT
  WARM
  COLD
}

enum CrmOwnerTeam {
  PH
  US
}

enum CrmTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum CrmDisposition {
  SCHEDULED_DISCOVERY
  INTERESTED_FOLLOW_UP
  NOT_INTERESTED
  NO_ANSWER_RETRY
  LEFT_VOICEMAIL
  WRONG_NUMBER
  DISQUALIFIED_JURISDICTION
  REFERRED_TO_OVERTURE
  BOOKING_LINK_SENT
}

enum CrmProvider {
  RINGCENTRAL
}

enum IntakeSourceType {
  MANUAL
  INBOUND_TEXT
  INBOUND_CALL
  FORM_FILL
  WEBINAR
  REGISTRATION
  IMPORT
}

enum IntakeMatchConfidence {
  NONE
  HIGH
  MEDIUM
  LOW
}

enum IntakeResolutionStatus {
  UNREVIEWED
  AUTO_ATTACHED
  REVIEW_REQUIRED
  RESOLVED
}

enum DuplicateReviewStatus {
  NONE
  POSSIBLE_DUPLICATE
  DUPLICATE_CONFIRMED
  NOT_DUPLICATE
}

enum ConflictCheckStatus {
  NOT_STARTED
  REVIEW_REQUIRED
  CLEARED
  CONFLICT_IDENTIFIED
  WAIVED
}

enum FinancialSourceSystem {
  COSMOLEX
  MANUAL
  IMPORT
  OTHER
}

enum BillingAccountType {
  TRUST
  OPERATING
  ACCOUNTS_RECEIVABLE
  REVENUE
  EXPENSE
  OTHER
}

enum MatterFinancialEventType {
  BILLED
  PAYMENT_RECEIVED
  TRUST_DEPOSIT
  TRUST_APPLIED
  OPERATING_DEPOSIT
  REFUND
  WRITE_OFF
  TRANSFER
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
}

enum InvoiceLineType {
  FEE
  ADVANCED_CLIENT_COST
}

enum PaymentMethod {
  CHECK
  ACH
  WIRE
  CASH
  CARD
  OTHER
}

enum PaymentStatus {
  POSTED
  VOID
}

enum PaymentDirection {
  INFLOW
  OUTFLOW
}

enum FinancialAttributionRole {
  LEAD_ATTORNEY
  TIMEKEEPER
  INTAKE_OWNER
  ORIGINATOR
  OTHER
}

enum TimeEntryPricingMode {
  HOURLY
  FLAT
}

enum TimeEntryStatus {
  DRAFT
  INVOICED
  VOID
}

enum KpiImportReportType {
  COLLECTIONS_BY_TIMEKEEPER
  BILLINGS_BY_TIMEKEEPER
  TRUST_RECEIPTS_JOURNAL
  TRUST_DISBURSEMENTS_JOURNAL
  INVOICE_PAYMENT_ALLOCATIONS
  OPERATING_RETAINER_BY_MATTER
}

enum KpiImportBatchStatus {
  PENDING
  IMPORTED
  FAILED
}

enum FinancialFeedSource {
  BANK_CSV
  CARD_CSV
  MANUAL
  COSMOLEX
  OTHER
}

enum FinancialAccountKind {
  OPERATING_BANK
  TRUST_BANK
  MONEY_MARKET
  CREDIT_CARD
  LIABILITY
  CLEARING
  OTHER
}

enum RawTransactionDirection {
  INFLOW
  OUTFLOW
}

enum TransactionReviewStatus {
  UNREVIEWED
  NEEDS_INFO
  MATCHED
  IGNORED
}

enum FinancialClassificationType {
  TRUST_DEPOSIT
  TRUST_TO_OPERATING_TRANSFER
  TRUST_MATTER_TRANSFER
  OPERATING_RETAINER_DEPOSIT
  OPERATING_RETAINER_APPLICATION
  DIRECT_FEE_PAYMENT
  REIMBURSED_COST_PAYMENT
  REFUND
  MERCHANT_FEE
  OWNER_TRANSFER
  EXPENSE
  IGNORE
}

enum OperatingCheckStatus {
  DRAFT
  ISSUED
  CLEARED
  VOID
}

enum TaskBillingStatus {
  BILLABLE
  BILLED
  NON_BILLABLE
  NO_CHARGE
}

enum MatterTimelineEventType {
  MANUAL_PHONE_CALL
  MANUAL_TEXT
  MANUAL_EMAIL
  MANUAL_MEETING
  MANUAL_INTERNAL_NOTE
  MANUAL_OTHER
  TASK_CREATED
  TASK_COMPLETED
  TIME_ENTRY_CREATED
  PIPELINE_STAGE_CHANGED
  MATTER_FIELD_UPDATED
}

enum MatterFieldType {
  TEXT
  LONG_TEXT
  DATE
  CURRENCY
  NUMBER
  TRUE_FALSE
  PICKLIST
  MULTI_SELECT_PICKLIST
  USER
  CONTACT
  LOOKUP
}

enum CrmMessageDirection {
  INBOUND
  OUTBOUND
}

enum CrmMessageStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  RECEIVED
}

enum CrmVerificationPurpose {
  REGISTRATION
  WATCH_ROOM
}

enum CrmAppointmentStatus {
  SCHEDULED
  SHOWED
  NO_SHOW
  CANCELED
  RESCHEDULED
}

// --- Multi-firm tenancy (v1 scaffolding) ---

enum FirmMemberRole {
  MEMBER
  ADMIN
}

// v2: firm job roles (used for calendar sharing / booking permissions).
// Keep FirmMemberRole for legacy admin gating; use FirmMemberKind for functional roles.
enum FirmMemberKind {
  INTAKER
  ATTORNEY
  PARALEGAL
  BOOKKEEPER
  ADMIN
  STAFF
}

model Firm {
  id       String @id @default(cuid())
  name     String
  slug     String @unique @db.VarChar(4)
  timeZone String @default("America/New_York")

  emailFromName                  String?
  emailFromAddress               String?
  emailReplyToAddress            String?
  emailSendingDomain             String?
  emailSendingDomainVerifiedAt   DateTime?

  members     FirmMember[]
  activeUsers User[]       @relation("UserActiveFirm")

  // Firm-scoped records (nullable firmId for now; backfilled in migration step)
  messageTemplates  MessageTemplate[]
  documentTemplates DocumentTemplate[]
  representationAgreementDrafts RepresentationAgreementDraft[]
  signingPackets    SigningPacket[]
  feeFeatures       FeeFeature[]
  helpArticles      HelpArticle[]
  helpTopics        HelpTopic[]
  managementPages   ManagementPage[]
  reportTables      ReportTable[]

  matters     Matter[]
  contacts    Contact[]
  crmContacts CrmContact[]

  pipelines       Pipeline[]
  pipelineStages  PipelineStage[]
  matterPipelines MatterPipeline[]

  billingAccounts          BillingAccount[]
  kpiImportBatches         KpiImportBatch[]
  financialEvents          MatterFinancialEvent[]
  financialAccounts        FinancialAccount[]
  financialImportBatches   FinancialImportBatch[]
  rawFinancialTransactions RawFinancialTransaction[]

  financialAccountCheckSequences FinancialAccountCheckSequence[]
  operatingChecks                OperatingCheck[]

  locations FirmLocation[]

  timeEntries     TimeEntry[]
  owners          FirmOwner[]
  ownershipStakes FirmOwnershipStake[]
  revenueSplits   FirmRevenueSplit[]

  invoiceNumberSequences InvoiceNumberSequence[]
  invoices               Invoice[]
  payments               Payment[]

  scheduledJobs ScheduledJob[]

  appointmentTypes AppointmentType[]

  tasks Task[]

  timelineEvents MatterTimelineEvent[]
  matterFieldDefinitions MatterFieldDefinition[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum FirmOwnerStatus {
  ACTIVE
  INACTIVE
}

enum RevenueSplitRecipient {
  LEGACY_GUARDIANS_MSO
}

model FirmOwner {
  id     String @id @default(cuid())
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  // PLLC ownership: attorney-person only.
  fullName  String
  barNumber String?
  barState  String?

  email String?

  status FirmOwnerStatus @default(ACTIVE)

  stakes FirmOwnershipStake[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([firmId, status])
  @@index([firmId, fullName])
}

model FirmRevenueSplit {
  id String @id @default(cuid())

  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  recipient RevenueSplitRecipient

  // Percent of revenue allocated to the recipient (bps; 100% = 10000).
  // Example: 15% = 1500, 30% = 3000.
  percentBps Int @default(0)

  effectiveFrom DateTime
  effectiveTo   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([firmId, recipient, effectiveFrom])
  @@index([firmId, effectiveTo])
}

model FirmOwnershipStake {
  id String @id @default(cuid())

  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  ownerId String
  owner   FirmOwner @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Ownership percent in basis points (100% = 10000).
  percentBps Int

  effectiveFrom DateTime
  effectiveTo   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([firmId, effectiveFrom])
  @@index([ownerId, effectiveFrom])
  @@index([firmId, effectiveTo])
}

model FirmLocation {
  id     String @id @default(cuid())
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  activeUsers  User[] @relation("UserActiveLocation")
  defaultUsers User[] @relation("UserDefaultLocation")

  members FirmLocationMember[]

  matters     Matter[]
  timeEntries TimeEntry[]
  invoices    Invoice[]

  name String
  slug String

  address1   String?
  address2   String?
  city       String?
  state      String?
  postalCode String?
  phone      String?

  sortOrder Int     @default(0)
  active    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([firmId, slug])
  @@index([firmId, sortOrder])
}

model FirmLocationMember {
  id String @id @default(cuid())

  firmLocationId String
  firmLocation   FirmLocation @relation(fields: [firmLocationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Mirror firm membership roles (simple for v1)
  role FirmMemberRole @default(MEMBER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // v1: assume each user belongs to exactly one location.
  @@unique([userId])
  @@index([firmLocationId])
}

model FirmMember {
  id     String @id @default(cuid())
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role FirmMemberRole @default(MEMBER)

  // Functional role in the firm (used for booking/calendar access).
  kind FirmMemberKind @default(STAFF)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([firmId, userId])
  @@index([userId])
  @@index([firmId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  role                   UserRole @default(STAFF)
  cosmolexTimekeeperName String?

  accounts Account[]
  sessions Session[]

  matters Matter[] @relation("MattersCreatedBy")

  createdTasks  Task[] @relation("TasksCreatedBy")
  assignedTasks Task[] @relation("TasksAssignedTo")
  matterTimelineEvents MatterTimelineEvent[] @relation("MatterTimelineActor")
  ownedContacts Contact[] @relation("ContactRelationshipOwner")

  intakeSpecialistMatters Matter[] @relation("MatterIntakeSpecialist")
  leadAttorneyMatters     Matter[] @relation("MatterLeadAttorney")

  ringCentralConnection RingCentralConnection?

  googleConnections GoogleConnection[]

  ownedAppointmentTypes           AppointmentType[]            @relation("AppointmentTypeOwner")
  createdBookingLinks             BookingLink[]                @relation("BookingLinkCreator")
  uploadedKpiImportBatches        KpiImportBatch[]             @relation("KpiImportBatchUploadedByUser")
  createdFinancialEvents          MatterFinancialEvent[]       @relation("MatterFinancialEventCreatedByUser")
  financialAttributions           MatterFinancialAttribution[]
  importedFinancialBatches        FinancialImportBatch[]       @relation("FinancialImportBatchImportedByUser")
  reviewedTransactionItems        TransactionReviewItem[]      @relation("TransactionReviewReviewedByUser")
  createdFinancialClassifications FinancialClassification[]    @relation("FinancialClassificationCreatedByUser")

  operatingChecksCreated OperatingCheck[] @relation("OperatingChecksCreatedBy")
  operatingChecksPrinted OperatingCheck[] @relation("OperatingChecksPrintedBy")

  timeEntriesCreated      TimeEntry[] @relation("TimeEntriesCreatedBy")
  timeEntriesAsTimekeeper TimeEntry[] @relation("TimeEntriesTimekeeper")

  invoicesCreated Invoice[] @relation("InvoicesCreatedBy")
  paymentsCreated Payment[] @relation("PaymentsCreatedBy")

  documentTemplatesCreated DocumentTemplate[] @relation("DocumentTemplatesCreatedBy")
  representationAgreementDraftsCreated RepresentationAgreementDraft[] @relation("RepresentationAgreementDraftsCreatedBy")
  signingPacketsCreated    SigningPacket[]    @relation("SigningPacketsCreatedBy")

  firmMemberships FirmMember[]

  // v1: user's active firm for scoping queries (until we ship a firm switcher UI)
  activeFirmId String?
  activeFirm   Firm?   @relation("UserActiveFirm", fields: [activeFirmId], references: [id], onDelete: SetNull)

  activeLocationId String?
  activeLocation   FirmLocation? @relation("UserActiveLocation", fields: [activeLocationId], references: [id], onDelete: SetNull)

  // v1: default/home location for scoping views like P&L by location.
  defaultLocationId String?
  defaultLocation   FirmLocation? @relation("UserDefaultLocation", fields: [defaultLocationId], references: [id], onDelete: SetNull)

  locationMemberships FirmLocationMember[]

  ftmHowOwnerSteps    FtmStep[] @relation("FtmHowOwner")
  ftmEnsureOwnerSteps FtmStep[] @relation("FtmEnsureOwner")
  ftmDoerSteps        FtmStep[] @relation("FtmDoer")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RingCentralConnection {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rcUserId      String?
  rcExtensionId String?

  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GoogleConnection {
  id          String @id @default(cuid())
  googleEmail String @unique

  // OAuth tokens
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String?

  connectedByUserId String?
  connectedByUser   User?   @relation(fields: [connectedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BillingAccount {
  id     String @id @default(cuid())
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  name        String
  accountType BillingAccountType

  sourceSystem FinancialSourceSystem @default(MANUAL)
  externalId   String?
  active       Boolean               @default(true)

  financialEventsFrom MatterFinancialEvent[] @relation("FinancialEventFromAccount")
  financialEventsTo   MatterFinancialEvent[] @relation("FinancialEventToAccount")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([firmId, name])
  @@index([firmId, accountType, active])
}

model FinancialAccount {
  id     String @id @default(cuid())
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  name String
  kind FinancialAccountKind

  institutionName String?
  last4           String?
  externalId      String?
  active          Boolean @default(true)

  importBatches   FinancialImportBatch[]
  rawTransactions RawFinancialTransaction[]

  operatingCheckSequence FinancialAccountCheckSequence?
  operatingChecks        OperatingCheck[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([firmId, name])
  @@index([firmId, kind, active])
}

model FinancialAccountCheckSequence {
  id String @id @default(cuid())

  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  financialAccountId String           @unique
  financialAccount   FinancialAccount @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)

  // Next proposed check number for this bank account.
  nextNumber Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([firmId])
}

model OperatingCheck {
  id String @id @default(cuid())

  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  financialAccountId String
  financialAccount   FinancialAccount @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)

  status OperatingCheckStatus @default(DRAFT)

  // Stored as text because some check stock uses leading zeros / suffixes.
  // NOTE: When toBePrinted=true, the check number is assigned at print-time.
  checkNumber String?
  issueDate   DateTime
  payeeName   String
  amountCents Int
  memo        String?

  // If true, this check is intended to be printed by LG (vs handwritten / printed elsewhere).
  toBePrinted Boolean @default(true)

  printedAt       DateTime?
  printedByUserId String?
  printedByUser   User?     @relation("OperatingChecksPrintedBy", fields: [printedByUserId], references: [id], onDelete: SetNull)

  // When a bank CSV transaction clears this check.
  clearedRawTransactionId String?
  clearedRawTransaction   RawFinancialTransaction? @relation("OperatingCheckClearedRawTransaction", fields: [clearedRawTransactionId], references: [id], onDelete: SetNull)

  createdByUserId String?
  createdByUser   User?   @relation("OperatingChecksCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([financialAccountId, checkNumber])
  @@index([firmId, financialAccountId, issueDate])
  @@index([status, issueDate])
  @@index([clearedRawTransactionId])
}

model FinancialImportBatch {
  id     String @id @default(cuid())
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  source    FinancialFeedSource
  accountId String?
  account   FinancialAccount?   @relation(fields: [accountId], references: [id], onDelete: SetNull)

  sourceFilename   String?
  sourceFileUrl    String?
  importedByUserId String?
  importedByUser   User?   @relation("FinancialImportBatchImportedByUser", fields: [importedByUserId], references: [id], onDelete: SetNull)

  rawTransactions RawFinancialTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([firmId, source, createdAt])
}

model RawFinancialTransaction {
  id     String @id @default(cuid())
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  accountId String?
  account   FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  importBatchId String?
  importBatch   FinancialImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  source          FinancialFeedSource
  transactionDate DateTime
  postedDate      DateTime?

  amountCents Int
  direction   RawTransactionDirection

  payee             String?
  description       String
  memo              String?
  externalReference String?

  rawData    Json
  dedupeHash String

  reviewItems     TransactionReviewItem[]
  classifications FinancialClassification[]

  clearedOperatingChecks OperatingCheck[] @relation("OperatingCheckClearedRawTransaction")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([firmId, dedupeHash])
  @@index([firmId, transactionDate])
  @@index([accountId, transactionDate])
  @@index([importBatchId])
}

model TransactionReviewItem {
  id String @id @default(cuid())

  rawTransactionId String
  rawTransaction   RawFinancialTransaction @relation(fields: [rawTransactionId], references: [id], onDelete: Cascade)

  status            TransactionReviewStatus      @default(UNREVIEWED)
  suggestedCategory FinancialClassificationType?
  reviewNotes       String?

  reviewedByUserId String?
  reviewedByUser   User?     @relation("TransactionReviewReviewedByUser", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  reviewedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([rawTransactionId])
}

model FinancialClassification {
  id String @id @default(cuid())

  rawTransactionId String
  rawTransaction   RawFinancialTransaction @relation(fields: [rawTransactionId], references: [id], onDelete: Cascade)

  classificationType FinancialClassificationType

  effectiveDate DateTime
  amountCents   Int

  matterId String?
  matter   Matter? @relation(fields: [matterId], references: [id], onDelete: SetNull)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  invoiceNumber String?
  notes         String?
  confidence    Int?

  createdByUserId String?
  createdByUser   User?   @relation("FinancialClassificationCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([classificationType, effectiveDate])
  @@index([matterId])
  @@index([invoiceNumber])
  @@index([rawTransactionId])
}

model KpiImportBatch {
  id     String @id @default(cuid())
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  sourceSystem FinancialSourceSystem @default(COSMOLEX)
  reportType   KpiImportReportType
  status       KpiImportBatchStatus  @default(PENDING)

  rangeStart DateTime?
  rangeEnd   DateTime?

  sourceFilename String?
  sourceFileUrl  String?
  errorMessage   String?

  uploadedByUserId String?
  uploadedByUser   User?   @relation("KpiImportBatchUploadedByUser", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  financialEvents MatterFinancialEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([firmId, reportType, createdAt])
  @@index([status])
}

model MatterFinancialEvent {
  id     String @id @default(cuid())
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  matterId String?
  matter   Matter? @relation(fields: [matterId], references: [id], onDelete: SetNull)

  eventType MatterFinancialEventType
  eventDate DateTime

  amountCents Int
  currency    String @default("USD")

  sourceSystem           FinancialSourceSystem @default(IMPORT)
  sourceReference        String?
  sourceInvoiceNumber    String?
  sourceMatterFileNumber String?
  sourceClientName       String?
  sourceMatterName       String?
  notes                  String?

  // Stable content hash for journal-imported rows so re-importing the same
  // file cannot double-count trust/payment events. Null for manual entries.
  dedupeHash String?

  fromAccountId String?
  fromAccount   BillingAccount? @relation("FinancialEventFromAccount", fields: [fromAccountId], references: [id], onDelete: SetNull)

  toAccountId String?
  toAccount   BillingAccount? @relation("FinancialEventToAccount", fields: [toAccountId], references: [id], onDelete: SetNull)

  importBatchId String?
  importBatch   KpiImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  createdByUserId String?
  createdByUser   User?   @relation("MatterFinancialEventCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  attributions MatterFinancialAttribution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([firmId, dedupeHash])
  @@index([firmId, eventType, eventDate])
  @@index([matterId, eventDate])
  @@index([importBatchId])
  @@index([sourceInvoiceNumber])
}

model MatterFinancialAttribution {
  id String @id @default(cuid())

  financialEventId String
  financialEvent   MatterFinancialEvent @relation(fields: [financialEventId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  displayName String
  role        FinancialAttributionRole @default(TIMEKEEPER)

  amountCents   Int
  percentageBps Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([financialEventId])
  @@index([userId])
  @@index([displayName])
}

// --- Scheduling / automations (v1) ---

enum AppointmentStatus {
  SCHEDULED
  CANCELED
}

model AppointmentType {
  id   String @id @default(cuid())
  slug String @unique
  name String

  // Multi-firm + ownership (v2)
  firmId String?
  firm   Firm?   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  ownerUserId String?
  ownerUser   User?   @relation("AppointmentTypeOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  // Public link id (unguessable) for sharing.
  publicId String @unique @default(cuid())

  // If true, public booking via /book/... is enabled.
  isPublic Boolean @default(true)

  durationMin      Int
  startIntervalMin Int @default(15)
  bufferBeforeMin  Int @default(0)
  bufferAfterMin   Int @default(0)
  minNoticeHours   Int @default(0)
  rollingWeeks     Int @default(8)
  maxPerDay        Int @default(6)

  assignees    AppointmentAssignee[]
  appointments Appointment[]

  bookingLinks BookingLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BookingLink {
  id String @id @default(cuid())

  token String @unique

  typeId String
  type   AppointmentType @relation(fields: [typeId], references: [id], onDelete: Cascade)

  createdByUserId String?
  createdByUser   User?   @relation("BookingLinkCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  // Use limits
  maxUses  Int @default(1)
  usedUses Int @default(0)

  // Optional expiry
  expiresAt DateTime?
  enabled   Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([typeId, enabled])
  @@index([token])
}

model AppointmentAssignee {
  id     String          @id @default(cuid())
  typeId String
  type   AppointmentType @relation(fields: [typeId], references: [id], onDelete: Cascade)

  googleEmail String
  displayName String?
  timeZone    String  @default("America/New_York")

  // Weekday office hours (minutes since midnight). MVP assumes Mon–Fri only.
  weekdayStartMin Int @default(540) // 09:00
  weekdayEndMin   Int @default(1020) // 17:00

  enabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([typeId, googleEmail])
  @@index([typeId, enabled])
}

model Appointment {
  id     String          @id @default(cuid())
  typeId String
  type   AppointmentType @relation(fields: [typeId], references: [id], onDelete: Cascade)

  status AppointmentStatus @default(SCHEDULED)

  startsAt DateTime
  endsAt   DateTime

  assignedGoogleEmail String
  googleEventId       String?

  clientName  String?
  clientEmail String?
  clientPhone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([typeId, startsAt])
  @@index([assignedGoogleEmail, startsAt])
}

enum ScheduledJobType {
  SEND_EMAIL
  SEND_SMS
}

enum ScheduledJobStatus {
  PENDING
  IN_PROGRESS
  DONE
  FAILED
}

model ScheduledJob {
  id String @id @default(cuid())

  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  runAt     DateTime
  type      ScheduledJobType
  status    ScheduledJobStatus @default(PENDING)
  attempts  Int                @default(0)
  lastError String?
  payload   Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, runAt])
  @@index([firmId, status, runAt])
}

enum MessageChannel {
  EMAIL
  SMS
}

model MessageTemplate {
  id      String         @id @default(cuid())
  firmId  String
  firm    Firm           @relation(fields: [firmId], references: [id], onDelete: Cascade)
  key     String
  channel MessageChannel
  name    String

  subject String?
  body    String
  isHtml  Boolean @default(false)

  // Optional attachment URL (v1; later: stored files)
  attachmentUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([firmId, key])
  @@index([firmId, channel])
}

model DocumentTemplate {
  id     String @id @default(cuid())
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  key         String
  name        String
  kind        DocumentTemplateKind
  description String?

  sourceFileName String
  mimeType       String
  sizeBytes      Int
  content        Bytes

  active Boolean @default(true)

  createdByUserId String?
  createdByUser   User?   @relation("DocumentTemplatesCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  signingPackets SigningPacket[]
  representationAgreementDrafts RepresentationAgreementDraft[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([firmId, key])
  @@index([firmId, kind])
  @@index([firmId, active])
}

model RepresentationAgreementDraft {
  id     String @id @default(cuid())
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  leadId String
  lead   CrmLeadPipeline @relation(fields: [leadId], references: [id], onDelete: Cascade)

  templateId String?
  template   DocumentTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  title          String
  status         String @default("DRAFT")
  sourceFileName String
  fileName       String
  mimeType       String
  sizeBytes      Int
  content        Bytes

  mergeData     Json
  missingTokens String[]

  reviewedAt DateTime?
  sentAt     DateTime?

  createdByUserId String?
  createdByUser   User?   @relation("RepresentationAgreementDraftsCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([firmId, createdAt])
  @@index([leadId, createdAt])
  @@index([templateId])
  @@index([status])
}

// DB-backed rate limiting for public, unauthenticated endpoints (booking,
// webinar). In-memory counters do not work across serverless instances.
model RateLimitHit {
  id        String   @id @default(cuid())
  key       String
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}

model SigningPacket {
  id     String @id @default(cuid())
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  matterId String?
  matter   Matter? @relation(fields: [matterId], references: [id], onDelete: SetNull)

  // CRM lead this packet belongs to (e.g. representation agreements sent
  // before a matter exists). Lets the Documenso webhook auto-stamp the
  // lead's RA-signed milestone on completion.
  leadId String?
  lead   CrmLeadPipeline? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  templateId String?
  template   DocumentTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  provider SigningProvider     @default(DOCUMENSO)
  status   SigningPacketStatus @default(DRAFT)

  title              String
  providerEnvelopeId String?
  providerStatus     String?
  sourceFileName     String?

  recipientsJson       Json
  signingUrlsJson      Json?
  providerResponseJson Json?
  errorMessage         String?

  createdByUserId String?
  createdByUser   User?   @relation("SigningPacketsCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([firmId, provider, status])
  @@index([firmId, providerEnvelopeId])
  @@index([matterId])
  @@index([leadId])
  @@index([templateId])
}

// --- Fee quote configurable price/features (v1) ---

enum FeeFeatureType {
  MONEY
  TEXT
  BOOLEAN
  NUMBER
}

model FeeFeature {
  id     String         @id @default(cuid())
  firmId String?
  firm   Firm?          @relation(fields: [firmId], references: [id], onDelete: SetNull)
  key    String         @unique
  label  String
  group  String?
  type   FeeFeatureType @default(MONEY)

  moneyCents  Int?     @default(0)
  textValue   String?
  boolValue   Boolean?
  numberValue Float?

  description String?
  sortOrder   Int     @default(0)
  active      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Help / FAQ library for chatbot + in-app reference ---

enum HelpContentFormat {
  MARKDOWN
  HTML
  PLAINTEXT
}

model HelpArticle {
  id     String            @id @default(cuid())
  firmId String?
  firm   Firm?             @relation(fields: [firmId], references: [id], onDelete: SetNull)
  slug   String            @unique
  title  String
  format HelpContentFormat @default(MARKDOWN)
  body   String

  tags      String[]
  published Boolean  @default(true)
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum PracticeArea {
  ESTATE_PLANNING
  ESTATE_ADMINISTRATION
  TRUST_ADMINISTRATION
  ELDER_LAW
  FIDUCIARY_SERVICES
  LITIGATION
}

enum MatterPartyRole {
  CLIENT
  CO_CLIENT
  OPPOSING_PARTY
  OPPOSING_COUNSEL
  WITNESS
  OTHER
}

model Matter {
  id     String       @id @default(cuid())
  firmId String?
  firm   Firm?        @relation(fields: [firmId], references: [id], onDelete: SetNull)
  status MatterStatus @default(DRAFT)

  // v0: keep it simple; later we can normalize people/roles.
  displayName String

  // Practice area / department (one per matter, drives P&L-by-area reporting).
  // Disputes live in LITIGATION (Option A); litigationSubjectArea records the
  // underlying subject of a litigation matter (e.g. a contested trust).
  practiceArea          PracticeArea?
  litigationSubjectArea PracticeArea?

  // lightweight contact/value fields for pipeline cards (MVP)
  primaryEmail        String?
  primaryPhone        String?
  estimatedValueCents Int     @default(0)

  // assignments for pipeline cards (MVP)
  intakeSpecialistId String?
  intakeSpecialist   User?   @relation("MatterIntakeSpecialist", fields: [intakeSpecialistId], references: [id], onDelete: SetNull)

  leadAttorneyId String?
  leadAttorney   User?   @relation("MatterLeadAttorney", fields: [leadAttorneyId], references: [id], onDelete: SetNull)

  // primary client contact (v1; later: MatterContact join for multiple parties)
  primaryContactId String?
  primaryContact   Contact? @relation("MatterPrimaryContact", fields: [primaryContactId], references: [id], onDelete: SetNull)

  referralSourceContactId String?
  referralSourceContact   Contact? @relation("MatterReferralSource", fields: [referralSourceContactId], references: [id], onDelete: SetNull)

  // Location attribution for reporting (P&L by location)
  primaryLocationId String?
  primaryLocation   FirmLocation? @relation(fields: [primaryLocationId], references: [id], onDelete: SetNull)

  convertedFromLeads CrmLeadPipeline[] @relation("LeadConvertedMatter")

  createdById String
  createdBy   User   @relation("MattersCreatedBy", fields: [createdById], references: [id])

  intake                   IntakeResponse?
  documents                GeneratedDocument[]
  signingPackets           SigningPacket[]
  pipelineLinks            MatterPipeline[]
  financialEvents          MatterFinancialEvent[]
  timeEntries              TimeEntry[]
  financialClassifications FinancialClassification[]

  invoices Invoice[]

  tasks Task[]
  timelineEvents MatterTimelineEvent[]
  fieldValues MatterFieldValue[]
  parties MatterContact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([firmId, primaryLocationId])
  @@index([referralSourceContactId])
  @@index([firmId, practiceArea])
}

// Parties on a matter (clients, co-clients, opposing parties/counsel,
// witnesses). Many-to-many between Matter and Contact with a role, so a
// matter can have any number of parties (litigation co-clients, etc.).
model MatterContact {
  id        String          @id @default(cuid())
  matterId  String
  matter    Matter          @relation(fields: [matterId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  role      MatterPartyRole @default(CLIENT)
  createdAt DateTime        @default(now())

  @@unique([matterId, contactId])
  @@index([matterId])
  @@index([contactId])
}

model Task {
  id     String @id @default(cuid())
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  matterId String?
  matter   Matter? @relation(fields: [matterId], references: [id], onDelete: SetNull)

  title       String
  description String @db.Text

  deadline DateTime?

  // 0-100, enforced by migration check constraint in increments of 10.
  completionPercent Int @default(0)

  billingStatus TaskBillingStatus @default(NON_BILLABLE)

  createdByUserId String
  createdByUser   User   @relation("TasksCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  assigneeUserId String
  assigneeUser   User   @relation("TasksAssignedTo", fields: [assigneeUserId], references: [id], onDelete: Restrict)

  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([firmId, completionPercent, deadline])
  @@index([firmId, assigneeUserId, completionPercent, deadline])
  @@index([matterId, completionPercent, deadline])
  @@index([createdByUserId])
}

model MatterTimelineEvent {
  id     String @id @default(cuid())
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  matterId String
  matter   Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  actorUserId String?
  actorUser   User?   @relation("MatterTimelineActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  eventType MatterTimelineEventType
  title     String
  body      String?
  details   Json?

  relatedTaskId           String?
  relatedTimeEntryId      String?
  relatedMatterPipelineId String?

  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([firmId, occurredAt])
  @@index([matterId, occurredAt])
  @@index([actorUserId, occurredAt])
  @@index([relatedTaskId])
  @@index([relatedTimeEntryId])
  @@index([relatedMatterPipelineId])
}

model MatterFieldDefinition {
  id     String @id @default(cuid())
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  key       String
  label     String
  type      MatterFieldType
  helpText  String?
  sortOrder Int             @default(0)
  active    Boolean         @default(true)
  required  Boolean         @default(false)

  // Picklist/multi-select options, and lookup target metadata.
  options      Json?
  lookupTarget String?

  values MatterFieldValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([firmId, key])
  @@index([firmId, active, sortOrder])
}

model MatterFieldValue {
  id String @id @default(cuid())

  matterId String
  matter   Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  fieldDefinitionId String
  fieldDefinition   MatterFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)

  value Json

  updatedByUserId String?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([matterId, fieldDefinitionId])
  @@index([fieldDefinitionId])
}

model TimeEntry {
  id     String @id @default(cuid())
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  matterId String
  matter   Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  locationId String?
  location   FirmLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  // Who did the work (billable timekeeper)
  timekeeperId String
  timekeeper   User   @relation("TimeEntriesTimekeeper", fields: [timekeeperId], references: [id], onDelete: Restrict)

  // Who created/edited the entry (admin/staff)
  createdByUserId String?
  createdByUser   User?   @relation("TimeEntriesCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  workDate  DateTime
  narrative String

  pricingMode TimeEntryPricingMode @default(HOURLY)

  // For HOURLY entries (store minutes; UI can accept tenths-of-hour)
  durationMinutes Int  @default(0)
  hourlyRateCents Int?

  // For FLAT entries (amount is stored directly on the entry)
  flatAmountCents Int?

  billable Boolean         @default(true)
  status   TimeEntryStatus @default(DRAFT)

  // Future: link to invoice line item
  invoiceId     String?
  invoiceLineId String?

  invoice     Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  invoiceLine InvoiceLine? @relation(fields: [invoiceLineId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([firmId, workDate])
  @@index([matterId, workDate])
  @@index([timekeeperId, workDate])
  @@index([status, workDate])
  @@index([firmId, locationId, workDate])
}

model InvoiceNumberSequence {
  id String @id @default(cuid())

  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  year    Int
  nextSeq Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([firmId, year])
  @@index([firmId, year])
}

model Invoice {
  id String @id @default(cuid())

  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  matterId String
  matter   Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  locationId String?
  location   FirmLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  status InvoiceStatus @default(DRAFT)

  // Immutable numbering
  firmSlugAtIssue String @db.VarChar(4)
  invoiceYear     Int
  invoiceSeq      Int
  invoiceNumber   String

  issueDate DateTime?
  dueDate   DateTime?

  currency String  @default("USD")
  notes    String?

  subtotalCents Int @default(0)
  totalCents    Int @default(0)

  createdByUserId String?
  createdByUser   User?   @relation("InvoicesCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  lines       InvoiceLine[]
  allocations PaymentAllocation[]
  timeEntries TimeEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([firmId, invoiceNumber])
  @@unique([firmId, invoiceYear, invoiceSeq])
  @@index([firmId, status, createdAt])
  @@index([matterId, createdAt])
  @@index([firmId, locationId, createdAt])
}

model InvoiceLine {
  id String @id @default(cuid())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  lineType InvoiceLineType @default(FEE)

  description    String
  quantityTenths Int    @default(0)
  unitPriceCents Int    @default(0)
  amountCents    Int

  timeEntryId String?

  sortOrder Int @default(0)

  timeEntries TimeEntry[]
  allocations PaymentAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId, sortOrder])
  @@index([lineType])
}

model Payment {
  id String @id @default(cuid())

  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  receivedAt DateTime
  method     PaymentMethod @default(OTHER)
  status     PaymentStatus @default(POSTED)

  direction PaymentDirection @default(INFLOW)

  payerName String?
  reference String?

  amountCents Int
  currency    String @default("USD")

  createdByUserId String?
  createdByUser   User?   @relation("PaymentsCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  allocations PaymentAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([firmId, receivedAt])
  @@index([status, receivedAt])
  @@index([firmId, direction, receivedAt])
}

model PaymentAllocation {
  id String @id @default(cuid())

  firmId String

  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  invoiceLineId String?
  invoiceLine   InvoiceLine? @relation(fields: [invoiceLineId], references: [id], onDelete: SetNull)

  amountCents Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([firmId, invoiceId])
  @@index([firmId, paymentId])
  @@index([invoiceLineId])
}

model Contact {
  id           String            @id @default(cuid())
  firmId       String?
  firm         Firm?             @relation(fields: [firmId], references: [id], onDelete: SetNull)
  displayName  String
  email        String?
  phone        String?
  organization String?
  categories   ContactCategory[]
  professionalType ContactProfessionalType?
  referralSourceStatus ReferralSourceStatus?
  relationshipOwnerId String?
  relationshipOwner   User? @relation("ContactRelationshipOwner", fields: [relationshipOwnerId], references: [id], onDelete: SetNull)
  notes        String?

  primaryMatters Matter[] @relation("MatterPrimaryContact")
  referredMatters Matter[] @relation("MatterReferralSource")
  matterParties MatterContact[]

  financialClassifications FinancialClassification[]

  convertedFromLeads CrmLeadPipeline[] @relation("LeadConvertedContact")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([displayName])
  @@index([firmId, professionalType])
  @@index([firmId, referralSourceStatus])
  @@index([relationshipOwnerId])
}

model ManagementPage {
  id      String  @id @default(cuid())
  firmId  String?
  firm    Firm?   @relation(fields: [firmId], references: [id], onDelete: SetNull)
  slug    String  @unique
  title   String
  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HelpTopic {
  id     String   @id @default(cuid())
  firmId String?
  firm   Firm?    @relation(fields: [firmId], references: [id], onDelete: SetNull)
  slug   String   @unique
  title  String
  body   String
  tags   String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ReportColumnType {
  TEXT
  NUMBER
  CURRENCY
  PERCENT
  DATE
}

model ReportTable {
  id     String  @id @default(cuid())
  firmId String?
  firm   Firm?   @relation(fields: [firmId], references: [id], onDelete: SetNull)
  slug   String  @unique
  name   String

  columns ReportColumn[]
  rows    ReportRow[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReportColumn {
  id      String      @id @default(cuid())
  tableId String
  table   ReportTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  key       String
  label     String
  type      ReportColumnType @default(TEXT)
  sortOrder Int              @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tableId, key])
  @@index([tableId, sortOrder])
}

model ReportRow {
  id      String      @id @default(cuid())
  tableId String
  table   ReportTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  rowKey    String
  label     String
  sortOrder Int    @default(0)
  data      Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tableId, rowKey])
  @@index([tableId, sortOrder])
}

model IntakeResponse {
  id       String @id @default(cuid())
  matterId String @unique
  matter   Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  // v0: JSON blob; evolve to structured columns as forms stabilize.
  data Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GeneratedDocument {
  id       String @id @default(cuid())
  matterId String
  matter   Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  type DocumentType

  // For MVP we can store generated content as a Blob later; for now store metadata.
  fileName String?
  fileUrl  String?

  createdAt DateTime @default(now())

  @@index([matterId])
}

model CrmContact {
  id        String       @id @default(cuid())
  firmId    String?
  firm      Firm?        @relation(fields: [firmId], references: [id], onDelete: SetNull)
  firstName String
  lastName  String
  email     String?
  phoneE164 String       @unique
  state     ContactState @default(UNKNOWN)

  phoneVerifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  registrations CrmRegistration[]
  tasks         CrmTask[]
  threads       CrmMessageThread[]
  verifications CrmVerification[]  @relation("CrmContactVerifications")

  prequalSubmissions CrmPrequalSubmission[]
  pipelineRecords    CrmLeadPipeline[]
}

model CrmCampaign {
  id   String @id @default(cuid())
  slug String @unique
  name String

  // Config defaults (MVP)
  defaultSenderName String  @default("Noah")
  bookingUrl        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  showings      CrmShowing[]
  registrations CrmRegistration[]
  tasks         CrmTask[]

  prequalSubmissions CrmPrequalSubmission[]
  pipelineRecords    CrmLeadPipeline[]
  dailySpends        CrmDailySpend[]
}

model CrmShowing {
  id         String      @id @default(cuid())
  campaignId String
  campaign   CrmCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  startsAt DateTime
  endsAt   DateTime

  createdAt DateTime @default(now())

  registrations CrmRegistration[]
  tasks         CrmTask[]

  @@unique([campaignId, startsAt])
  @@index([campaignId])
  @@index([startsAt])
}

model CrmRegistration {
  id String @id @default(cuid())

  contactId String
  contact   CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  campaignId String
  campaign   CrmCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  showingId String
  showing   CrmShowing @relation(fields: [showingId], references: [id], onDelete: Cascade)

  status     String  @default("REGISTERED") // TODO enum later when we wire attendance
  watchToken String? @unique

  phoneVerifiedAt DateTime?

  createdAt DateTime @default(now())

  verifications CrmVerification[] @relation("CrmRegistrationVerifications")

  prequalSubmissions CrmPrequalSubmission[] @relation("CrmRegistrationPrequal")

  @@index([campaignId])
  @@index([showingId])
  @@index([contactId])
}

model CrmVerification {
  id      String                 @id @default(cuid())
  purpose CrmVerificationPurpose

  contactId String
  contact   CrmContact @relation("CrmContactVerifications", fields: [contactId], references: [id], onDelete: Cascade)

  registrationId String?
  registration   CrmRegistration? @relation("CrmRegistrationVerifications", fields: [registrationId], references: [id], onDelete: Cascade)

  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)

  sentAt     DateTime  @default(now())
  verifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
  @@index([registrationId])
  @@index([purpose, expiresAt])
}

model CrmPrequalSubmission {
  id String @id @default(cuid())

  contactId String
  contact   CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  campaignId String
  campaign   CrmCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  leadId String?
  lead   CrmLeadPipeline? @relation("LeadPrequalSubmissions", fields: [leadId], references: [id], onDelete: SetNull)

  registrationId String?
  registration   CrmRegistration? @relation("CrmRegistrationPrequal", fields: [registrationId], references: [id], onDelete: SetNull)

  source    String  @default("internal") // typeform|internal
  qualified Boolean @default(false)

  // Denormalized key answers for reporting
  estatePlanningStage String?
  primaryConcern      String?
  docsInPlace         String[]
  estateWorthBand     String?
  investReady         Boolean?
  readyToStart        String?
  additionalNotes     String?

  answers Json

  createdAt DateTime @default(now())

  @@index([campaignId, createdAt])
  @@index([contactId, createdAt])
  @@index([leadId, createdAt])
}

model CrmLeadPipeline {
  id String @id @default(cuid())

  contactId String
  contact   CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  campaignId String
  campaign   CrmCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  dateAdded       DateTime @default(now())
  additionalNotes String?

  intakeCallAttempted   Boolean   @default(false)
  intakeCallAttemptedAt DateTime?

  appt1Scheduled Boolean               @default(false)
  appt1At        DateTime?
  appt1Status    CrmAppointmentStatus?

  leadQualityScore Int?

  appt2Scheduled Boolean               @default(false)
  appt2At        DateTime?
  appt2Status    CrmAppointmentStatus?

  // Closing metrics (manual for now)
  closed             Boolean @default(false)
  cashCollectedCents Int     @default(0)
  revenueCents       Int     @default(0)

  // Lead → engagement workflow
  proposalPreparedAt DateTime?
  raPreparedAt       DateTime?
  raSentAt           DateTime?
  raSignedAt         DateTime?

  // Intake review / risk flags
  sourceType             IntakeSourceType      @default(MANUAL)
  duplicateReviewStatus  DuplicateReviewStatus @default(NONE)
  duplicateReviewNotes   String?
  conflictCheckStatus    ConflictCheckStatus   @default(REVIEW_REQUIRED)
  conflictCheckNotes     String?
  conflictCheckUpdatedAt DateTime?

  // Lead → client conversion
  convertedAt        DateTime?
  convertedContactId String?
  convertedContact   Contact?  @relation("LeadConvertedContact", fields: [convertedContactId], references: [id], onDelete: SetNull)
  convertedMatterId  String?
  convertedMatter    Matter?   @relation("LeadConvertedMatter", fields: [convertedMatterId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messageThreads     CrmMessageThread[]     @relation("LeadMessageThreads")
  prequalSubmissions CrmPrequalSubmission[] @relation("LeadPrequalSubmissions")
  representationAgreementDrafts RepresentationAgreementDraft[]
  signingPackets                SigningPacket[]

  @@unique([contactId, campaignId])
  @@index([campaignId, dateAdded])
  @@index([sourceType, dateAdded])
  @@index([duplicateReviewStatus])
  @@index([conflictCheckStatus])
}

model CrmDailySpend {
  id String @id @default(cuid())

  campaignId String
  campaign   CrmCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // Store at midnight ET as a DateTime for now (we'll enforce in UI).
  day         DateTime
  amountCents Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, day])
  @@index([campaignId, day])
}

// --- Matter pipelines (Kanban) ---

model MatterPipeline {
  id     String  @id @default(cuid())
  firmId String?
  firm   Firm?   @relation(fields: [firmId], references: [id], onDelete: SetNull)

  matterId String
  matter   Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  stageId String
  stage   PipelineStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  // ordering within a stage column (optional; used later)
  sortKey Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matterId, pipelineId])
  @@index([pipelineId, stageId])
  @@index([matterId])
}

model Pipeline {
  id          String  @id @default(cuid())
  firmId      String?
  firm        Firm?   @relation(fields: [firmId], references: [id], onDelete: SetNull)
  name        String
  description String?
  sortOrder   Int     @default(0)

  stages      PipelineStage[]
  matterLinks MatterPipeline[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PipelineStage {
  id         String   @id @default(cuid())
  firmId     String?
  firm       Firm?    @relation(fields: [firmId], references: [id], onDelete: SetNull)
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  name      String
  colorHex  String? // optional UI color
  sortOrder Int     @default(0)

  matters MatterPipeline[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pipelineId, sortOrder])
}

// --- Forever Task Maps (FTMs) ---

model FtmMap {
  id          String  @id @default(cuid())
  title       String
  description String?

  // v1: structured steps (later: diagram nodes/edges)
  steps FtmStep[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FtmStep {
  id    String @id @default(cuid())
  mapId String
  map   FtmMap @relation(fields: [mapId], references: [id], onDelete: Cascade)

  sortOrder Int    @default(0)
  name      String

  // Role assignments (simplified RACI)
  howOwnerUserId String?
  howOwnerUser   User?   @relation("FtmHowOwner", fields: [howOwnerUserId], references: [id], onDelete: SetNull)

  ensureOwnerUserId String?
  ensureOwnerUser   User?   @relation("FtmEnsureOwner", fields: [ensureOwnerUserId], references: [id], onDelete: SetNull)

  doerUserId String?
  doerUser   User?   @relation("FtmDoer", fields: [doerUserId], references: [id], onDelete: SetNull)
  doerRole   String?

  // Light documentation
  howToMd    String?
  doneWhenMd String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mapId, sortOrder])
}

model CrmTask {
  id        String     @id @default(cuid())
  contactId String
  contact   CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  campaignId String
  campaign   CrmCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  showingId String?
  showing   CrmShowing? @relation(fields: [showingId], references: [id], onDelete: SetNull)

  type      CrmTaskType
  priority  CrmPriority
  ownerTeam CrmOwnerTeam
  status    CrmTaskStatus @default(OPEN)

  dueAt       DateTime
  lastTouchAt DateTime?

  disposition CrmDisposition?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, dueAt])
  @@index([campaignId])
  @@index([contactId])
}

model CrmMessageThread {
  id String @id @default(cuid())

  contactId String
  contact   CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  leadId String?
  lead   CrmLeadPipeline? @relation("LeadMessageThreads", fields: [leadId], references: [id], onDelete: SetNull)

  provider               CrmProvider
  providerConversationId String?

  lastMessageAt DateTime?

  intakeResolutionStatus IntakeResolutionStatus @default(UNREVIEWED)
  matchConfidence        IntakeMatchConfidence  @default(NONE)
  matchSummary           String?
  needsConflictCheck     Boolean                @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages CrmMessage[]

  @@index([contactId])
  @@index([leadId])
  @@index([intakeResolutionStatus, lastMessageAt])
}

model CrmMessage {
  id String @id @default(cuid())

  threadId String
  thread   CrmMessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  direction      CrmMessageDirection
  fromNumberE164 String
  toNumberE164   String
  body           String

  providerMessageId String?          @unique
  status            CrmMessageStatus

  sentAt     DateTime?
  receivedAt DateTime?

  createdAt DateTime @default(now())

  @@index([threadId, createdAt])
}
